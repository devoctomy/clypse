@using clypse.core.Password
@using clypse.core.Enums
@inherits Blazing.Mvvm.Components.MvvmComponentBase<clypse.portal.Application.ViewModels.PasswordFieldViewModel>

<div class="mb-3">
    <label class="form-label">@Label</label>
    <div class="input-group">
        <input type="@(ViewModel.ShowPassword ? "text" : "password")"
               class="form-control"
               @bind="ViewModel.Value"
               @bind:after="OnPasswordChanged"
               @oninput="OnPasswordInput"
               placeholder="@Placeholder"
               readonly="@IsReadOnly" />

        @if (!IsReadOnly || ShowRevealButton)
        {
            <button class="btn btn-secondary" type="button" @onclick="ViewModel.TogglePasswordVisibilityCommand.Execute">
                <i class="bi bi-@(ViewModel.ShowPassword ? "eye-slash" : "eye")"></i>
            </button>
        }

        @if (!IsReadOnly && ShowGeneratorButton)
        {
            <button class="btn btn-success" type="button" @onclick="ViewModel.ShowGeneratorCommand.Execute" title="Generate Password">
                <i class="bi bi-calculator"></i>
            </button>
        }
    </div>

    @* Password Strength Indicator *@
    @if (!string.IsNullOrEmpty(ViewModel.Value) && ShowStrengthIndicator)
    {
        <div class="mt-2">
            <div class="d-flex justify-content-between align-items-center mb-1">
                <small class="text-muted">Password Strength</small>
                <small class="@ViewModel.ComplexityColorClass fw-bold">@ViewModel.ComplexityText</small>
            </div>
            <div class="progress" style="height: 6px;">
                <div class="progress-bar @ViewModel.ComplexityBackgroundColorClass"
                     role="progressbar"
                     style="width: @ViewModel.ComplexityPercentage%"
                     aria-valuenow="@ViewModel.ComplexityPercentage"
                     aria-valuemin="0"
                     aria-valuemax="100">
                </div>
            </div>
            @if (!string.IsNullOrEmpty(ViewModel.PasswordComplexityResults?.AdditionalInfo))
            {
                <small class="text-muted d-block mt-1">@ViewModel.PasswordComplexityResults.AdditionalInfo</small>
            }
        </div>
    }
</div>

<PasswordGeneratorDialog
    Show="ViewModel.ShowPasswordGenerator"
    OnPasswordGenerated="HandlePasswordGenerated"
    OnCancel="ViewModel.HideGeneratorCommand.Execute" />
