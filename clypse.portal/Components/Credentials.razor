@inherits MvvmComponentBase<CredentialsViewModel>
@using Blazing.Mvvm.Components
@using clypse.portal.Application.ViewModels
@using clypse.portal.Models

<div class="credentials-page">
    <h2>Credentials</h2>
    
    @if (ViewModel.CurrentVault != null)
    {
        <div class="credentials-search-bar">
            <div class="d-flex justify-content-end align-items-center">
                <div class="input-group">
                    <span class="input-group-text">
                        <i class="bi bi-search"></i>
                    </span>
                    <input type="text" 
                           class="form-control" 
                           placeholder="Search secrets..." 
                           @bind="ViewModel.SearchTerm" 
                           @bind:event="oninput"
                           @onkeyup="() => ViewModel.HandleSearch()" />
                    @if (!string.IsNullOrEmpty(ViewModel.SearchTerm))
                    {
                        <button class="btn btn-secondary" @onclick="() => ViewModel.ClearSearchCommand.Execute(null)">
                            <i class="bi bi-x"></i>
                        </button>
                    }
                </div>
            </div>
        </div>
        
        @if (ViewModel.FilteredEntries.Any())
        {
            <div class="credentials-grid-responsive">
                @foreach (var entry in ViewModel.FilteredEntries)
                {
                    <div class="credential-card-responsive" @onclick="() => ViewModel.ViewSecretCommand.Execute(entry.Id)">
                        <div class="credential-actions-responsive">
                            <button class="btn btn-sm btn-success me-1" title="Edit Secret" @onclick="() => ViewModel.EditSecretCommand.Execute(entry.Id)" @onclick:stopPropagation="true">
                                <i class="bi bi-pencil"></i>
                            </button>
                            <button class="btn btn-sm btn-danger" title="Delete Secret" @onclick="() => ViewModel.ShowDeleteConfirmationFor(entry.Id, entry.Name)" @onclick:stopPropagation="true">
                                <i class="bi bi-trash"></i>
                            </button>
                        </div>
                        <div class="credential-content">
                            @if (!string.IsNullOrEmpty(entry.Name))
                            {
                                <div class="credential-field-name">
                                    <strong>@entry.Name</strong>
                                </div>
                            }
                            @if (!string.IsNullOrEmpty(entry.Description))
                            {
                                <div class="credential-field-description">
                                    @entry.Description
                                </div>
                            }
                            @if (!string.IsNullOrEmpty(entry.Tags))
                            {
                                <div class="credential-field-tags">
                                    @foreach (var tag in entry.Tags.Split(',', StringSplitOptions.RemoveEmptyEntries))
                                    {
                                        <span class="badge bg-secondary me-1">@tag.Trim()</span>
                                    }
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            @if (!string.IsNullOrEmpty(ViewModel.SearchTerm))
            {
                <p class="text-muted">No secrets match your search.</p>
            }
            else
            {
                <p class="text-muted">No secrets found in this vault.</p>
            }
        }
    }
    else
    {
        <div class="alert alert-warning" role="alert">
            <i class="bi bi-exclamation-triangle me-2"></i>
            No vault is currently unlocked. Please go back to vaults and unlock a vault first.
        </div>
    }
</div>

@if (ViewModel.ShowImportDialog)
{
    <ImportSecretsDialog Show="ViewModel.ShowImportDialog" OnCancel="@(() => ViewModel.CloseImportDialogCommand.Execute(null))" OnImport="@((result) => ViewModel.HandleImportSecretsCommand.Execute(result))" />
}

<ConfirmDialog 
    Show="ViewModel.ShowDeleteConfirmation" 
    Message="@ViewModel.DeleteConfirmationMessage" 
    IsProcessing="ViewModel.IsDeletingSecret"
    OnConfirm="@(() => ViewModel.HandleDeleteSecretCommand.Execute(null))" 
    OnCancel="@(() => ViewModel.CancelDeleteConfirmationCommand.Execute(null))" />

<LoadingDialog Show="ViewModel.IsLoadingSecret" Message="Loading secret..." />
<LoadingDialog Show="ViewModel.IsSavingSecret" Message="Saving secret..." />

<SecretDialog 
    Show="ViewModel.ShowSecretDialog" 
    Secret="ViewModel.CurrentSecret" 
    Mode="ViewModel.SecretDialogMode"
    OnSave="@((secret) => ViewModel.HandleSecretDialogSaveCommand.Execute(secret))" 
    OnCancel="@(() => ViewModel.CloseSecretDialogCommand.Execute(null))" />
