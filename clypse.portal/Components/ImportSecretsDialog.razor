@using clypse.core.Enums
@using Microsoft.AspNetCore.Components.Forms
@using clypse.portal.Application.ViewModels
@inherits Blazing.Mvvm.Components.MvvmComponentBase<ImportSecretsDialogViewModel>

@if (Show)
{
    <div class="modal" style="display: block; background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title">
                        <i class="bi bi-upload me-2"></i>
                        Import Secrets from CSV
                    </h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="ViewModel.CancelCommand.Execute"></button>
                </div>
                <div class="modal-body">
                    @if (!string.IsNullOrEmpty(ViewModel.ErrorMessage))
                    {
                        <div class="alert alert-danger" role="alert">
                            <i class="bi bi-exclamation-triangle me-2"></i>
                            @ViewModel.ErrorMessage
                        </div>
                    }

                    <div class="mb-3">
                        <label for="csvFile" class="form-label">
                            <strong>Select CSV File</strong>
                        </label>
                        <InputFile id="csvFile"
                                   OnChange="@HandleFileSelected"
                                   accept=".csv"
                                   class="form-control"
                                   disabled="@ViewModel.IsImporting" />
                        <small class="form-text text-muted">
                            Select a CSV file containing secrets to import.
                        </small>
                    </div>

                    @if (!string.IsNullOrEmpty(ViewModel.SelectedFileName))
                    {
                        <div class="mb-3">
                            <div class="alert alert-info" role="alert">
                                <i class="bi bi-file-earmark-text me-2"></i>
                                Selected file: <strong>@ViewModel.SelectedFileName</strong>
                            </div>
                        </div>
                    }

                    <div class="mb-3">
                        <label for="csvFormat" class="form-label">
                            <strong>CSV Format</strong>
                        </label>
                        <select id="csvFormat"
                                class="form-select"
                                @bind="ViewModel.SelectedFormat"
                                disabled="@ViewModel.IsImporting">
                            @foreach (var format in ViewModel.AvailableFormats)
                            {
                                <option value="@format">@ImportSecretsDialogViewModel.GetFormatDisplayName(format)</option>
                            }
                        </select>
                        <small class="form-text text-muted">
                            Select the format of your CSV file to ensure proper mapping of fields.
                        </small>
                    </div>

                    @if (ViewModel.PreviewData?.Any() == true)
                    {
                        <div class="mb-3">
                            <label class="form-label">
                                <strong>Preview (first 3 rows)</strong>
                            </label>
                            <div class="table-responsive" style="max-height: 200px; overflow-y: auto;">
                                <table class="table table-sm table-bordered">
                                    <thead class="table-light">
                                        <tr>
                                            @if (ViewModel.Headers?.Any() == true)
                                            {
                                                @foreach (var header in ViewModel.Headers)
                                                {
                                                    <th>@header</th>
                                                }
                                            }
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var row in ViewModel.PreviewData.Take(3))
                                        {
                                            <tr>
                                                @if (ViewModel.Headers?.Any() == true)
                                                {
                                                    @foreach (var header in ViewModel.Headers)
                                                    {
                                                        <td>@(row.ContainsKey(header) ? row[header] : "")</td>
                                                    }
                                                }
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    }
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="ViewModel.CancelCommand.Execute" disabled="@ViewModel.IsImporting">
                        Cancel
                    </button>
                    <button type="button"
                            class="btn btn-primary"
                            @onclick="ViewModel.ImportCommand.Execute"
                            disabled="@(!ViewModel.CanImport || ViewModel.IsImporting)">
                        @if (ViewModel.IsImporting)
                        {
                            <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                            <span>Importing...</span>
                        }
                        else
                        {
                            <i class="bi bi-upload me-2"></i>
                            <span>Import</span>
                        }
                    </button>
                </div>
            </div>
        </div>
    </div>
}
