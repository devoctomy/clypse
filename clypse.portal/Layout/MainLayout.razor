@inherits MvvmLayoutComponentBase<MainLayoutViewModel>

<div class="d-flex flex-column mobile-safe-layout">
    <main class="flex-grow-1">
        @Body
    </main>
    
    <footer class="bg-light py-3 mt-auto mobile-safe-footer">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-md-12 text-center">
                    <small class="text-muted">@ViewModel.AppSettings.CopyrightMessage</small>
                    <br />
                    <small class="text-muted">
                        Version 
                        <span class="version-number @(ViewModel.UpdateAvailable ? "update-available" : "")" 
                              @onclick="() => ViewModel.HandleVersionClickCommand.Execute(null)" 
                              title="Click to view version history">
                            @Globals.Version
                            @if (ViewModel.UpdateAvailable)
                            {
                                <i class="bi bi-exclamation-circle text-warning ms-1"></i>
                            }
                        </span>
                    </small>
                </div>
            </div>
        </div>
    </footer>
</div>

<ChangesDialog Show="@ViewModel.ShowChangesDialog" 
ShowUpdateButton="@ViewModel.UpdateAvailable" 
AvailableVersion="@Globals.Version"
OnClose="@(() => ViewModel.HandleCloseChangesDialogCommand.Execute(null))"
OnUpdate="@(() => ViewModel.HandleInstallUpdateCommand.Execute(null))" />

@using Blazing.Mvvm.Components
@using clypse.portal.Application.ViewModels
@using clypse.portal.Models
