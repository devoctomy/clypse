@page "/"
@page "/home"
@layout HomeLayout
@inherits MvvmComponentBase<HomeViewModel>
@using Blazing.Mvvm.Components
@using clypse.portal.Application.ViewModels

<PageTitle>Clypse Portal - Home</PageTitle>

@if (ViewModel.CurrentPage == "vaults")
{
    <Vaults />
}
else if (ViewModel.CurrentPage == "credentials")
{
    <Credentials />
}

<VerifyDialog Show="ViewModel.ShowVerifyDialog" Results="ViewModel.VerifyResults" OnClose="@(() => ViewModel.CloseVerifyDialogCommand.Execute(null))" />
<VaultDeleteConfirmDialog Show="ViewModel.ShowDeleteVaultDialog" 
                          VaultToDelete="ViewModel.VaultToDelete" 
                          IsDeleting="ViewModel.IsDeletingVault"
                          ErrorMessage="@ViewModel.DeleteVaultErrorMessage"
                          OnConfirm="@(() => ViewModel.HandleDeleteVaultConfirmCommand.Execute(null))" 
                          OnCancel="@(() => ViewModel.CancelDeleteVaultCommand.Execute(null))" />
<VaultCreateDialog Show="ViewModel.ShowCreateVaultDialog"
                   IsCreating="ViewModel.IsCreatingVault"
                   ErrorMessage="@ViewModel.CreateVaultErrorMessage"
                   OnCreateVault="@((req) => ViewModel.HandleCreateVaultFromDialogCommand.Execute(req))"
                   OnCancel="@(() => ViewModel.CancelCreateVaultCommand.Execute(null))" />
