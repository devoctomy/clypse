@page "/login"
@inherits MvvmComponentBase<LoginViewModel>
@using Blazing.Mvvm.Components
@using clypse.portal.Application.ViewModels
@using clypse.portal.Models

<PageTitle>Clypse Portal - Login</PageTitle>

<!-- Title Bar (similar to HomeLayout) -->
<div class="text-white p-3 d-flex justify-content-between align-items-center" style="background-color: var(--clypse-primary);">
    <div class="d-flex align-items-center">
        @if (ViewModel.AppSettings.ShowLogoInTitleBar)
        {
            <img src="/images/titlebar-logo.png" alt="@ViewModel.AppSettings.ApplicationTitle" class="me-2" style="height: 32px;" />
        }
        else
        {
            <h4 class="mb-0">@ViewModel.AppSettings.ApplicationTitle</h4>
        }
    </div>
    <button class="theme-switcher" @onclick="() => ViewModel.ToggleThemeCommand.Execute(null)" title="Toggle theme">
        <i class="bi @ViewModel.ThemeIcon"></i>
    </button>
</div>

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card">
                <div class="card-header">
                    <div class="text-center">
                        <img src="/images/icon-192.png" alt="Clypse" style="margin: 8px 0;" />
                    </div>
                </div>
                <div class="card-body">
                    @if (ViewModel.ShowUsersList && ViewModel.SavedUsers.Any())
                    {
                        <!-- Saved Users List -->
                        <div class="mb-3">
                            <div class="d-grid gap-2">
                                @foreach (var user in ViewModel.SavedUsers)
                                {
                                    <div class="input-group">
                                        <button type="button" class="btn btn-outline-primary d-flex align-items-center flex-grow-1" @onclick="() => ViewModel.SelectUserCommand.Execute(user)" disabled="@ViewModel.IsLoading">
                                            @if (ViewModel.IsLoading)
                                            {
                                                <span class="spinner-border spinner-border-sm me-3" role="status" aria-hidden="true"></span>
                                            }
                                            else if (user.WebAuthnCredential != null)
                                            {
                                                <i class="bi bi-fingerprint me-3" title="Biometric login available"></i>
                                            }
                                            else
                                            {
                                                <i class="bi bi-person-circle me-3"></i>
                                            }
                                            <span>@user.Email</span>
                                        </button>
                                        <button type="button" class="btn btn-outline-danger" @onclick="() => ViewModel.RemoveUserCommand.Execute(user)" title="Remove user">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </div>
                                }
                            </div>
                            <div class="text-center mt-3">
                                <button type="button" class="btn btn-link" @onclick="() => ViewModel.ShowLoginFormCommand.Execute(null)">
                                    Use different account
                                </button>
                            </div>
                        </div>
                    }
                    else
                    {
                        <!-- Login Form -->
                        <EditForm Model="@ViewModel" OnValidSubmit="@((ctx) => ViewModel.HandleLoginCommand.Execute(null))">
                            <DataAnnotationsValidator />
                            <ValidationSummary />

                            @if (ViewModel.SavedUsers.Any())
                            {
                                <div class="mb-3 text-center">
                                    <button type="button" class="btn btn-outline-secondary btn-sm" @onclick="() => ViewModel.ShowUsersListCommandCommand.Execute(null)">
                                        <i class="bi bi-people me-1"></i>Remembered Users
                                    </button>
                                </div>
                            }

                            @if (!ViewModel.PasswordResetRequired && !ViewModel.ForgotPasswordMode)
                            {
                                <div class="mb-3">
                                    <div class="input-group">
                                        <span class="input-group-text">
                                            <i class="bi bi-person"></i>
                                        </span>
                                        <InputText id="username" class="form-control" @bind-Value="ViewModel.Username" placeholder="Enter your username" readonly="@ViewModel.IsUsernameReadonly" />
                                    </div>
                                </div>

                                <div class="mb-3">
                                    <div class="input-group">
                                        <span class="input-group-text">
                                            <i class="bi bi-lock"></i>
                                        </span>
                                        <InputText id="password" type="password" class="form-control" @bind-Value="ViewModel.Password" placeholder="Enter your password" />
                                    </div>
                                </div>

                                @if (ViewModel.ShowRememberMe)
                                {
                                    <div class="mb-3">
                                        <div class="form-check">
                                            <InputCheckbox id="rememberMe" class="form-check-input" @bind-Value="ViewModel.RememberMe" />
                                            <label class="form-check-label" for="rememberMe">
                                                Remember me
                                            </label>
                                        </div>
                                    </div>
                                }
                            }

                            @if (!ViewModel.PasswordResetRequired && !ViewModel.ForgotPasswordMode)
                            {
                                <div class="d-grid">
                                    <button type="submit" class="btn btn-primary" disabled="@ViewModel.IsLoading">
                                        @if (ViewModel.IsLoading)
                                        {
                                            <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                                            <span>Logging in...</span>
                                        }
                                        else
                                        {
                                            <span>Login</span>
                                        }
                                    </button>
                                </div>

                                <div class="text-center mt-3">
                                    <button type="button" class="btn btn-link" @onclick="() => ViewModel.ShowForgotPasswordCommand.Execute(null)">
                                        Forgot your password?
                                    </button>
                                </div>
                            }

                            @if (ViewModel.ForgotPasswordMode && !ViewModel.ForgotPasswordCodeSent)
                            {
                                <div class="mt-3">
                                    <div class="alert alert-info">
                                        <i class="bi bi-info-circle me-2"></i>
                                        Enter your username or email address and we'll send you a verification code to reset your password.
                                    </div>
                                    
                                    <div class="mb-3">
                                        <div class="input-group">
                                            <span class="input-group-text">
                                                <i class="bi bi-person"></i>
                                            </span>
                                            <InputText id="forgotPasswordUsername" class="form-control" @bind-Value="ViewModel.ForgotPasswordUsername" placeholder="Enter your username or email" />
                                        </div>
                                    </div>

                                    <div class="d-grid gap-2">
                                        <button type="button" class="btn btn-primary" @onclick="() => ViewModel.HandleForgotPasswordCommand.Execute(null)" disabled="@(ViewModel.IsLoading || string.IsNullOrWhiteSpace(ViewModel.ForgotPasswordUsername))">
                                            @if (ViewModel.IsLoading)
                                            {
                                                <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                                                <span>Sending code...</span>
                                            }
                                            else
                                            {
                                                <span>Send Verification Code</span>
                                            }
                                        </button>
                                        <button type="button" class="btn btn-outline-secondary" @onclick="() => ViewModel.CancelForgotPasswordCommand.Execute(null)" disabled="@ViewModel.IsLoading">
                                            Back to Login
                                        </button>
                                    </div>
                                </div>
                            }

                            @if (ViewModel.ForgotPasswordMode && ViewModel.ForgotPasswordCodeSent)
                            {
                                <div class="mt-3">
                                    <div class="alert alert-success">
                                        <i class="bi bi-check-circle me-2"></i>
                                        Verification code sent! Check your email/phone and enter the code below with your new password.
                                    </div>
                                    
                                    <div class="mb-3">
                                        <div class="input-group">
                                            <span class="input-group-text">
                                                <i class="bi bi-shield-check"></i>
                                            </span>
                                            <InputText id="verificationCode" class="form-control" @bind-Value="ViewModel.VerificationCode" placeholder="Enter verification code" />
                                        </div>
                                    </div>

                                    <div class="mb-3">
                                        <div class="input-group">
                                            <span class="input-group-text">
                                                <i class="bi bi-lock"></i>
                                            </span>
                                            <InputText id="newPasswordForgot" type="password" class="form-control" @bind-Value="ViewModel.NewPassword" placeholder="Enter new password" />
                                        </div>
                                    </div>

                                    <div class="mb-3">
                                        <div class="input-group">
                                            <span class="input-group-text">
                                                <i class="bi bi-lock-fill"></i>
                                            </span>
                                            <InputText id="confirmPasswordForgot" type="password" class="form-control" @bind-Value="ViewModel.ConfirmPassword" placeholder="Confirm new password" />
                                        </div>
                                    </div>

                                    <div class="d-grid gap-2">
                                        <button type="button" class="btn btn-success" @onclick="() => ViewModel.HandleConfirmForgotPasswordCommand.Execute(null)" disabled="@(ViewModel.IsLoading || string.IsNullOrWhiteSpace(ViewModel.VerificationCode) || string.IsNullOrEmpty(ViewModel.NewPassword) || ViewModel.NewPassword != ViewModel.ConfirmPassword)">
                                            @if (ViewModel.IsLoading)
                                            {
                                                <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                                                <span>Resetting password...</span>
                                            }
                                            else
                                            {
                                                <span>Reset Password</span>
                                            }
                                        </button>
                                        <button type="button" class="btn btn-outline-secondary" @onclick="() => ViewModel.CancelForgotPasswordCommand.Execute(null)" disabled="@ViewModel.IsLoading">
                                            Back to Login
                                        </button>
                                    </div>
                                </div>
                            }

                            @if (ViewModel.PasswordResetRequired)
                            {
                                <div class="mt-3">
                                    <div class="mb-3">
                                        <div class="input-group">
                                            <span class="input-group-text">
                                                <i class="bi bi-lock"></i>
                                            </span>
                                            <InputText id="newPassword" type="password" class="form-control" @bind-Value="ViewModel.NewPassword" placeholder="Enter new password" />
                                        </div>
                                    </div>

                                    <div class="mb-3">
                                        <div class="input-group">
                                            <span class="input-group-text">
                                                <i class="bi bi-lock-fill"></i>
                                            </span>
                                            <InputText id="confirmPassword" type="password" class="form-control" @bind-Value="ViewModel.ConfirmPassword" placeholder="Confirm new password" />
                                        </div>
                                    </div>

                                    <div class="d-grid">
                                        <button type="button" class="btn btn-primary" @onclick="() => ViewModel.HandlePasswordChangeCommand.Execute(null)" disabled="@(ViewModel.IsLoading || string.IsNullOrEmpty(ViewModel.NewPassword) || ViewModel.NewPassword != ViewModel.ConfirmPassword)">
                                            @if (ViewModel.IsLoading)
                                            {
                                                <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                                                <span>Changing password...</span>
                                            }
                                            else
                                            {
                                                <span>Change Password</span>
                                            }
                                        </button>
                                    </div>
                                </div>
                            }

                            @if (!string.IsNullOrEmpty(ViewModel.ErrorMessage))
                            {
                                <div class="alert alert-danger mt-3" role="alert">
                                    @ViewModel.ErrorMessage
                                </div>
                            }
                        </EditForm>
                    }
                    @if (Globals.IsDebugBuild)
                    {
                        <div class="text-center mt-3">
                            <a href="/test" class="btn btn-link">Go to Test Page</a>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<!-- WebAuthn Setup Modal -->
@if (ViewModel.ShowWebAuthnPrompt)
{
    <div class="modal d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">
                        <i class="bi bi-fingerprint me-2"></i>
                        Enable Biometric Login
                    </h5>
                </div>
                <div class="modal-body">
                    @if (!string.IsNullOrEmpty(ViewModel.WebAuthnErrorMessage))
                    {
                        <div class="alert alert-danger">
                            <i class="bi bi-exclamation-triangle me-2"></i>
                            @ViewModel.WebAuthnErrorMessage
                        </div>
                        <div class="d-grid">
                            <button type="button" class="btn btn-primary" @onclick="() => ViewModel.DismissWebAuthnErrorCommand.Execute(null)">
                                Continue to App
                            </button>
                        </div>
                    }
                    else
                    {
                        <div class="text-center mb-3">
                            <i class="bi bi-fingerprint" style="font-size: 3rem; color: var(--bs-primary);"></i>
                        </div>
                        <p class="text-center mb-4">
                            Would you like to use <strong>biometrics</strong> for quicker login next time?
                            <br />
                            <small class="text-muted">Use Touch ID, Windows Hello, or security keys for faster access.</small>
                        </p>
                        
                        <div class="d-grid gap-2">
                            <button type="button" class="btn btn-primary" @onclick="() => ViewModel.HandleWebAuthnSetupCommand.Execute(null)" disabled="@ViewModel.IsWebAuthnProcessing">
                                @if (ViewModel.IsWebAuthnProcessing)
                                {
                                    <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                                    <span class="ms-2">Setting up biometric login...</span>
                                }
                                else
                                {
                                    <i class="bi bi-fingerprint me-2"></i>
                                    <span>Yes, Enable Biometric Login</span>
                                }
                            </button>
                            <button type="button" class="btn btn-outline-secondary" @onclick="() => ViewModel.SkipWebAuthnSetupCommand.Execute(null)" disabled="@ViewModel.IsWebAuthnProcessing">
                                <i class="bi bi-skip-forward me-2"></i>
                                Skip for Now
                            </button>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
}
