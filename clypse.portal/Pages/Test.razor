@page "/test"
@inherits Blazing.Mvvm.Components.MvvmComponentBase<clypse.portal.Application.ViewModels.TestViewModel>

<PageTitle>Clypse Portal - Test</PageTitle>

<div class="container mt-4 test-page-container" style="min-height: calc(100vh + 200px); padding-bottom: 100px;">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card">
                <div class="card-header">
                    <h3 class="text-center">Login</h3>
                </div>
                <div class="card-body">
                    @if (!ViewModel.IsAuthenticated)
                    {
                        <div>
                            <div class="mb-3">
                                <label for="username" class="form-label">Username:</label>
                                <input id="username" class="form-control" @bind="ViewModel.LoginUsername" placeholder="Enter your username" />
                            </div>

                            <div class="mb-3">
                                <label for="password" class="form-label">Password:</label>
                                <input id="password" type="password" class="form-control" @bind="ViewModel.LoginPassword" placeholder="Enter your password" />
                            </div>

                            <div class="d-grid">
                                <button type="button" class="btn btn-primary" @onclick="ViewModel.HandleLoginCommand.Execute" disabled="@ViewModel.IsLoading">
                                    @if (ViewModel.IsLoading)
                                    {
                                        <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                                        <span>Logging in...</span>
                                    }
                                    else
                                    {
                                        <span>Login</span>
                                    }
                                </button>
                            </div>

                            @if (!string.IsNullOrEmpty(ViewModel.ErrorMessage))
                            {
                                <div class="alert alert-danger mt-3" role="alert">
                                    @ViewModel.ErrorMessage
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="text-center">
                            <h4 class="text-success mb-4">Successfully Logged In!</h4>

                            <div class="row">
                                <div class="col-12 mb-3">
                                    <label class="form-label fw-bold">Access Token:</label>
                                    <textarea class="form-control" rows="3" readonly>@(ViewModel.AccessToken ?? "Not available")</textarea>
                                </div>

                                <div class="col-12 mb-3">
                                    <label class="form-label fw-bold">ID Token:</label>
                                    <textarea class="form-control" rows="3" readonly>@(ViewModel.IdToken ?? "Not available")</textarea>
                                </div>
                            </div>

                            <div class="d-grid gap-2">
                                <button class="btn btn-success" @onclick="ViewModel.HandleTestClypseCommand.Execute" disabled="@ViewModel.IsTestingClypse">
                                    @if (ViewModel.IsTestingClypse)
                                    {
                                        <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                                        <span>Testing Clypse...</span>
                                    }
                                    else
                                    {
                                        <span>Test Clypse Core</span>
                                    }
                                </button>
                                <button class="btn btn-secondary" @onclick="ViewModel.HandleLogoutCommand.Execute">Logout</button>
                            </div>

                            @if (!string.IsNullOrEmpty(ViewModel.ClypseTestResult))
                            {
                                <div class="alert alert-info mt-3" role="alert">
                                    <strong>Clypse Test Result:</strong><br/>
                                    @ViewModel.ClypseTestResult
                                </div>
                            }

                            @if (!string.IsNullOrEmpty(ViewModel.ClypseTestError))
                            {
                                <div class="alert alert-danger mt-3" role="alert">
                                    <strong>Clypse Test Error:</strong><br/>
                                    @ViewModel.ClypseTestError
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
            <div class="text-center mt-3">
                <a href="/login" class="btn btn-link">Back to Login Page</a>
            </div>
        </div>
    </div>

    <div class="row justify-content-center mt-4">
        <div class="col-md-6">
            <div class="card">
                <div class="card-header">
                    <h3 class="text-center">Cryptography Tests</h3>
                </div>
                <div class="card-body">
                    <div class="d-grid gap-2">
                        <button class="btn btn-primary" @onclick="ViewModel.HandleTestKeyDerivationCommand.Execute" disabled="@ViewModel.IsTestingKeyDerivation">
                            @if (ViewModel.IsTestingKeyDerivation)
                            {
                                <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                                <span>Testing Key Derivation...</span>
                            }
                            else
                            {
                                <span>Test Key Derivation Algorithms</span>
                            }
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row justify-content-center mt-4">
        <div class="col-md-8">
            <div class="card">
                <div class="card-header">
                    <h3 class="text-center">🔐 WebAuthn Tests</h3>
                </div>
                <div class="card-body">
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label for="webauthnUsername" class="form-label">Username:</label>
                            <input id="webauthnUsername" class="form-control" @bind="ViewModel.WebAuthnUsername" placeholder="Enter username" />
                        </div>
                        <div class="col-md-6 d-flex align-items-end">
                            <small class="text-muted">Status: @ViewModel.WebAuthnStatus</small>
                        </div>
                    </div>

                    <div class="d-grid gap-2 d-md-flex justify-content-md-start mb-3">
                        <button class="btn btn-success" @onclick="ViewModel.HandleWebAuthnRegisterCommand.Execute" disabled="@(ViewModel.IsWebAuthnProcessing || string.IsNullOrWhiteSpace(ViewModel.WebAuthnUsername))">
                            @if (ViewModel.IsWebAuthnProcessing)
                            {
                                <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                                <span>Registering...</span>
                            }
                            else
                            {
                                <span>🔑 Register Credential</span>
                            }
                        </button>

                        <button class="btn btn-primary" @onclick="ViewModel.HandleWebAuthnAuthenticateCommand.Execute" disabled="@(ViewModel.IsWebAuthnProcessing || ViewModel.WebAuthnCredential == null)">
                            @if (ViewModel.IsWebAuthnProcessing)
                            {
                                <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                                <span>Authenticating...</span>
                            }
                            else
                            {
                                <span>🔓 Authenticate</span>
                            }
                        </button>

                        <button class="btn btn-secondary" @onclick="ViewModel.HandleWebAuthnClearCommand.Execute">
                            🗑️ Clear
                        </button>
                    </div>

                    @if (ViewModel.WebAuthnCredential != null)
                    {
                        <div class="alert alert-info">
                            <strong>Registered Credential:</strong><br/>
                            <small>ID: @ViewModel.WebAuthnCredential.CredentialID[..Math.Min(20, ViewModel.WebAuthnCredential.CredentialID.Length)]...</small><br/>
                            <small>User: @ViewModel.WebAuthnCredential.Username</small><br/>
                            <small>PRF Enabled: @ViewModel.WebAuthnCredential.PrfEnabled</small>
                        </div>
                    }

                    <div class="mt-3">
                        <h5>Activity Log:</h5>
                        <div id="webauthnLog" class="border rounded p-3" style="height: 300px; overflow-y: auto; background: #f8f9fa; font-family: monospace; font-size: 0.85rem; white-space: pre-wrap;">@((MarkupString)ViewModel.WebAuthnLog.Replace("\n", "<br/>"))</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@if (ViewModel.ShowKeyDerivationResults && ViewModel.KeyDerivationResults != null)
{
    <div class="modal" tabindex="-1" style="display: block; background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Key Derivation Benchmark Results</h5>
                    <button type="button" class="btn-close" @onclick="() => ViewModel.ShowKeyDerivationResults = false"></button>
                </div>
                <div class="modal-body">
                    <table class="table">
                        <thead>
                            <tr>
                                <th>Algorithm</th>
                                <th>Average Time (ms)</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var result in ViewModel.KeyDerivationResults.Results)
                            {
                                <tr>
                                    <td>@result.Algorithm</td>
                                    <td>@result.Average!.Value.TotalMilliseconds.ToString("F2")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="() => ViewModel.ShowKeyDerivationResults = false">Close</button>
                </div>
            </div>
        </div>
    </div>
}
